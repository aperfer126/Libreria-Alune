generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  role      Role       @default(USER)
  orders    Order[]
  favorites Favorite[]
  createdAt DateTime   @default(now())
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model Genre {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]
}

model Book {
  id            Int         @id @default(autoincrement())
  title         String
  author        String
  isbn          String?     @unique
  price         Decimal     @db.Decimal(10, 2)
  stock         Int         @default(0)
  coverUrl      String?
  description   String?     @db.Text
  genres        Genre[]
  publishedAt   DateTime?
  publisher     String?
  pages         Int?
  binding       String?
  createdAt     DateTime    @default(now())
  orderItems    OrderItem[]
  favorites     Favorite[]
}

model Favorite {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  book      Book     @relation(fields: [bookId], references: [id])
  bookId    Int
  createdAt DateTime @default(now())

  @@unique([userId, bookId])
}

model Order {
  id              Int         @id @default(autoincrement())
  user            User        @relation(fields: [userId], references: [id])
  userId          Int
  status          OrderStatus @default(PENDING)
  stripeSessionId String?
  total           Decimal     @db.Decimal(10, 2)
  shippingAddress String?     @db.Text
  items           OrderItem[]
  createdAt       DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model OrderItem {
  id       Int     @id @default(autoincrement())
  order    Order   @relation(fields: [orderId], references: [id])
  orderId  Int
  book     Book    @relation(fields: [bookId], references: [id])
  bookId   Int
  quantity Int
  price    Decimal @db.Decimal(10, 2)
}
